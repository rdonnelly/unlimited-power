{
  "name": "unlimited-power",
  "version": "1.7.1",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx expo start --dev-client",
    "dev": "npx expo start --dev-client",
    "check:deps": "npx expo install --check",
    "check:doctor": "npx expo-doctor@latest",
    "check:lint": "eslint .",
    "check:ts": "tsc",
    "build:android:dev": "npx eas-cli@latest build --platform android --profile development",
    "build:android:dev:local": "npx eas-cli@latest build --platform android --profile development --local",
    "build:ios:dev": "npx eas-cli@latest build --platform ios --profile development",
    "build:ios:simulator": "npx eas-cli@latest build --platform ios --profile development-simulator",
    "build:ios:simulator:local": "npx eas-cli@latest build --platform ios --profile development-simulator --local",
    "push:android": "npx eas-cli@latest build --platform android --auto-submit",
    "push:ios": "npx eas-cli@latest build --platform ios --auto-submit",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@bugsnag/expo": "^55.0.0",
    "@expo/html-elements": "^55.0.3",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@lodev09/react-native-true-sheet": "^3.9.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/native-stack": "^7.14.9",
    "@shopify/flash-list": "^2.3.1",
    "@tanstack/query-async-storage-persister": "^5.95.2",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "expo": "~55.0.5",
    "expo-application": "~55.0.8",
    "expo-asset": "~55.0.7",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.8",
    "expo-dev-client": "~55.0.9",
    "expo-device": "~55.0.9",
    "expo-file-system": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.5",
    "expo-linking": "~55.0.7",
    "expo-sharing": "~55.0.10",
    "expo-splash-screen": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "lodash": "^4.17.23",
    "qs": "^6.15.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "^4.24.0",
    "react-native-worklets": "^0.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/lodash": "^4.17.24",
    "@types/qs": "^6.15.0",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^8.56.0",
    "eslint-config-universe": "^12.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@shopify/flash-list",
        "react-native-gesture-handler",
        "react-native-reanimated",
        "react-native-screens",
        "react-native-worklets"
      ]
    }
  },
  "private": true
}
